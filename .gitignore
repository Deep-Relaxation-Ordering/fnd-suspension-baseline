# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Tooling
.ruff_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store

# Claude Code session state (local; not portable)
.claude/

# Run outputs (large simulation artefacts kept out of git; recorded in lab notes)
runs/
*.npy
*.npz
*.h5
*.parquet

# Generated figure PDFs — matplotlib embeds /CreationDate, so PDFs churn
# byte-for-byte on every notebook re-run even when the plotted data is
# identical. PNG previews stay tracked; PDFs are regenerated on demand.
notebooks/figures/**/*.pdf

# Audit outputs — generated CSVs from one-off analysis scripts
notebooks/*_audit.csv
notebooks/data/*_audit.csv
